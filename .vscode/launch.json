{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run rPPG Test",
            "type": "debugpy",
            "request": "launch",
            "module": "rppg.test_rppg",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "KERAS_BACKEND": "jax",
                "JAX_PLATFORMS": "cpu"
            }
        }
    ]
}